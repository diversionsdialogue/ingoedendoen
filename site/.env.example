# Sanity-koppeling: vul in na `sanity init` in ../studio.
# Zonder deze variabelen gebruikt de site de lokale export (data/content.json).
SANITY_PROJECT_ID=
SANITY_DATASET=production

# bol affiliate-SiteId: nodig om affiliate-links op te bouwen bij het bouwen van de site.
# Zonder deze waarde worden productblokken niet getoond (geen link = geen commissie).
BOL_SITE_ID=
