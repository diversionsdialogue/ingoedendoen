---
import Base from '../layouts/Base.astro';
---
<Base title="Pagina niet gevonden" noindex={true}>
  <div class="plain-page" style="text-align:center;">
    <h1>Oeps, deze pagina bestaat niet (meer)</h1>
    <p style="font-family:var(--font-sans); color:var(--color-text-secondary); line-height:1.7; margin-bottom:28px;">
      De pagina die je zoekt is verhuisd of bestaat niet meer.
      Kijk in het artikeloverzicht of ga terug naar de homepage.
    </p>
    <a class="igd-btn" href="/artikelen-overzicht/">Naar alle artikelen</a>
  </div>
</Base>
